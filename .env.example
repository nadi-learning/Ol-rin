# b2c-rewrite backend env. Copy to .env for local dev.
NODE_ENV=development
PORT=3010
FRONTEND_URL=http://localhost:5174

# App connection — NON-superuser role so Postgres RLS actually binds.
DATABASE_URL=postgresql://b2c_app:b2c@localhost:5435/b2c
# Migration/owner connection — runs DDL + creates the app role + RLS policies.
MIGRATE_DATABASE_URL=postgresql://b2c:b2c@localhost:5435/b2c

REDIS_URL=redis://localhost:6381

# Better Auth — installed in S0, wired in S1. Optional until then.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
