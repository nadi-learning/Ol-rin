+/* The waiting-room signboard. `.shire-`-scoped — the standing global-leak
+   hygiene (S23), same as .par-/.tut-/.crew-/.jrnl-. */
+
+.shire-root {
+  min-height: 100vh;
+  min-height: 100dvh;
+  display: flex;
+  flex-direction: column;
+}
+
+.shire-top {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  padding: 18px 24px;
+}
+.shire-who {
+  font-size: 14px;
+  font-weight: 600;
+  color: var(--ink-soft);
+}
+.shire-signout {
+  background: none;
+  border: 1px solid var(--border);
+  border-radius: var(--r-pill);
+  padding: 7px 16px;
+  font-size: 13.5px;
+  color: var(--ink-muted);
+  cursor: pointer;
+}
+.shire-signout:hover {
+  color: var(--ink-soft);
+  background: var(--surface-sunk);
+}
+
+/* Centred in what's LEFT after the header, not in the viewport — centring on
+   the viewport puts the board a header's height too low. */
+.shire-stage {
+  flex: 1;
+  display: grid;
+  place-items: center;
+  padding: 16px 20px 64px;
+}
+
+/* ── the board ──────────────────────────────────────────────────────────── */
+
+.shire-board {
+  position: relative;
+  width: min(560px, 100%);
+  /* Room for the posts to show beneath the plank. */
+  padding-bottom: 34px;
+}
+
+/* Two posts, angled out slightly so the board reads as planted rather than
+   floating. Behind the plank (z-index) so the plank's shadow falls on them. */
+.shire-post {
+  position: absolute;
+  bottom: 0;
+  width: 12px;
+  height: 76px;
+  border-radius: 3px;
+  background: linear-gradient(180deg, #b98a55, #8d6538);
+  z-index: 0;
+}
+.shire-post--l {
+  left: 16%;
+  transform: rotate(-3deg);
+}
+.shire-post--r {
+  right: 16%;
+  transform: rotate(3deg);
+}
+
+.shire-plank {
+  position: relative;
+  z-index: 1;
+  text-align: center;
+  padding: 34px 30px 32px;
+  border-radius: 14px;
+  /* Warm wood, with the grain suggested by two soft bands rather than an
+     image — this page must not depend on an asset that may never arrive. */
+  background:
+    linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(0, 0, 0, 0.06)),
+    linear-gradient(90deg, #d8a86a, #c9955a 40%, #d3a163 70%, #c08a4e);
+  border: 2px solid #9a6f3f;
+  box-shadow: 0 10px 24px rgba(80, 50, 15, 0.22);
+  color: #3a2410;
+}
+
+.shire-eyebrow {
+  margin: 0 0 6px;
+  font-size: 11.5px;
+  font-weight: 700;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+  color: #6b4a24;
+}
+
+.shire-head {
+  margin: 0 0 10px;
+  font-size: 26px;
+  line-height: 1.15;
+  color: #33200d;
+}
+
+.shire-body {
+  margin: 0 auto 22px;
+  max-width: 40ch;
+  font-size: 14.5px;
+  line-height: 1.55;
+  color: #4b3018;
+}
+
+.shire-call {
+  margin: 0 0 4px;
+  font-size: 13.5px;
+  font-weight: 600;
+  letter-spacing: 0.02em;
+  color: #5c3c1c;
+}
+
+/* 🔑 The founder asked for the number "in larger form" — it is the one thing
+   on this page anyone needs, so it is set as the page's real headline and sized
+   to be read at arm's length. `clamp` so it never overflows a 320px phone,
+   which a fixed 34px does (the number is 14 characters wide). */
+.shire-number {
+  display: inline-block;
+  font-size: clamp(22px, 6.4vw, 34px);
+  font-weight: 800;
+  letter-spacing: 0.01em;
+  line-height: 1.2;
+  color: #2b1908;
+  text-decoration: none;
+  border-bottom: 3px solid rgba(43, 25, 8, 0.35);
+  padding-bottom: 2px;
+  /* Never break a phone number across two lines. */
+  white-space: nowrap;
+}
+.shire-number:hover {
+  border-bottom-color: #2b1908;
+}
+
+.shire-foot {
+  margin: 14px 0 0;
+  font-size: 14px;
+  color: #4b3018;
+}
+
+@media (max-width: 480px) {
+  .shire-plank {
+    padding: 26px 18px 24px;
+  }
+  .shire-head {
+    font-size: 22px;
+  }
+  /* The posts crowd the plank on a narrow screen — pull them inward. */
+  .shire-post--l {
+    left: 10%;
+  }
+  .shire-post--r {
+    right: 10%;
+  }
+}
